#!/usr/bin/env bash
# cdev - thin VPS helper for Coder development environment operations.
#
# This script is the VPS-side operator tool.  It does NOT:
#   - build Docker images
#   - patch template source files
#   - run the catalog generator
#   - refresh or render generated output
#
# Safety rules:
#   - Never modifies UFW / fail2ban / iptables / nftables.
#   - Never prunes Docker volumes (they are Coder-managed).
#   - Never deletes workspace data.
#   - sync-generated writes into a temp directory, validates, then atomically
#     switches the live template directory under a flock lock.

set -Eeuo pipefail
IFS=$'\n\t'

VERSION="2026-05-15.v10.0"

ROOT="${CODER_CDE_ROOT:-/opt/coder-cde}"
DOMAIN="${DOMAIN:-${CODER_DOMAIN:-code.549304.xyz}}"
COMPOSE_FILE="${COMPOSE_FILE:-$ROOT/docker-compose.yml}"
TEMPLATE_NAME="${TEMPLATE_NAME:-devbox}"
DEVBOX_IMAGE="${DEVBOX_IMAGE:-coder-devbox:latest}"
CODER_URL="${CODER_URL:-https://${DOMAIN}}"
BACKUP_ROOT="${CDEV_BACKUP_ROOT:-$ROOT/backups}"
LOCK_DIR="${CDEV_LOCK_DIR:-/opt/coder-cde/.locks}"

log() { printf '\033[1;34m==>\033[0m %s\n' "$*" >&2; }
warn() { printf '\033[1;33mWARN:\033[0m %s\n' "$*" >&2; }
err() { printf '\033[1;31mERROR:\033[0m %s\n' "$*" >&2; }
die() {
  err "$*"
  exit 1
}

have() {
  command -v "$1" >/dev/null 2>&1
}

need_root() {
  [[ "${EUID}" -eq 0 ]] || die "this command requires root; use sudo."
}

need_root_dir() {
  [[ -d "$ROOT" ]] || die "ROOT=$ROOT not found. Set CODER_CDE_ROOT=/opt/coder-cde"
}

need_compose() {
  need_root_dir
  [[ -f "$COMPOSE_FILE" ]] || die "Docker Compose file not found: $COMPOSE_FILE"
}

dc() {
  need_compose
  docker compose -f "$COMPOSE_FILE" "$@"
}

compose_services() {
  dc config --services 2>/dev/null || true
}

coder_service() {
  local svc
  svc="$(compose_services | grep -x 'coder' | head -n1 || true)"
  [[ -n "$svc" ]] || svc="$(compose_services | grep -Ei 'coder|coderd' | head -n1 || true)"
  [[ -n "$svc" ]] || die "cannot find coder service in docker-compose.yml"
  printf '%s\n' "$svc"
}

# ---------------------------------------------------------------------------
# template-dir -- locate the active Coder template directory
# ---------------------------------------------------------------------------
template_dir() {
  local d

  if [[ -n "${TEMPLATE_DIR:-}" && -f "$TEMPLATE_DIR/main.tf.json" ]]; then
    printf '%s\n' "$TEMPLATE_DIR"
    return
  fi
  if [[ -n "${TEMPLATE_DIR:-}" && -f "$TEMPLATE_DIR/main.tf" ]]; then
    printf '%s\n' "$TEMPLATE_DIR"
    return
  fi

  for d in \
    "$ROOT/templates/$TEMPLATE_NAME" \
    "$ROOT/templates/devbox" \
    "$ROOT/template/$TEMPLATE_NAME" \
    "$ROOT/devbox"; do
    if [[ -f "$d/main.tf.json" ]] || [[ -f "$d/main.tf" ]]; then
      printf '%s\n' "$d"
      return
    fi
  done

  d="$(find "$ROOT" -type f \( -name main.tf -o -name main.tf.json \) 2>/dev/null | head -n1 || true)"
  [[ -n "$d" ]] || die "cannot find template directory. Set TEMPLATE_DIR."
  dirname "$d"
}

# ---------------------------------------------------------------------------
# info
# ---------------------------------------------------------------------------
cmd_info() {
  need_root_dir

  local td svc
  td="$(template_dir 2>/dev/null || true)"
  svc="$(coder_service 2>/dev/null || true)"

  cat <<EOF
cdev version:        $VERSION
ROOT:                $ROOT
DOMAIN:              $DOMAIN
COMPOSE_FILE:        $COMPOSE_FILE
Coder service:       ${svc:-not found}
CODER_URL:           $CODER_URL
Wildcard URL:        *.${DOMAIN}
Template name:       $TEMPLATE_NAME
Template dir:        ${td:-not found}
Lock dir:            $LOCK_DIR
EOF
}

# ---------------------------------------------------------------------------
# doctor
# ---------------------------------------------------------------------------
cmd_doctor() {
  cmd_info || true
  echo

  log "docker compose services"
  compose_services || true
  echo

  log "docker compose ps"
  dc ps || true
  echo

  log "template check"
  cmd_check_generated || true
  echo

  log "image tags check"
  cmd_check_images || true
  echo

  log "local coder health"
  curl -sv http://127.0.0.1:7080/ 2>&1 | tail -80 || true
  echo

  if have nginx; then
    log "nginx test"
    nginx -t || true
  fi
}

# ---------------------------------------------------------------------------
# ps / logs / restart
# ---------------------------------------------------------------------------
cmd_ps() { dc ps "$@"; }

cmd_logs() {
  local svc

  if [[ "$#" -gt 0 && -n "${1:-}" ]]; then
    svc="$1"
    shift
  else
    svc="$(coder_service)"
  fi

  [[ -n "$svc" ]] || die "cannot find coder service in docker-compose.yml"
  dc logs --tail="${TAIL:-200}" -f "$svc" "$@"
}

cmd_restart() {
  if [[ "$#" -gt 0 ]]; then
    dc restart "$@"
  else
    dc restart
  fi
}

# ---------------------------------------------------------------------------
# template-dir
# ---------------------------------------------------------------------------
cmd_template_dir() {
  template_dir
}

# ---------------------------------------------------------------------------
# push-template
# ---------------------------------------------------------------------------
cmd_push_template() {
  local td svc rc
  td="$(template_dir)"

  [[ -n "${CODER_SESSION_TOKEN:-}" ]] || die "CODER_SESSION_TOKEN is required.  Run: CODER_SESSION_TOKEN='...' cdev push-template"

  log "push template: name=$TEMPLATE_NAME dir=$td url=$CODER_URL"

  if have coder; then
    (
      cd "$td"
      CODER_URL="$CODER_URL" CODER_SESSION_TOKEN="$CODER_SESSION_TOKEN" \
        coder templates push --yes --directory "$td" "$TEMPLATE_NAME"
    )
    return
  fi

  svc="$(coder_service)"
  log "host coder CLI not found; using Docker Compose service '$svc' as CLI runner"

  local tmp remote_dir
  tmp="$(mktemp -d)"
  remote_dir="/tmp/cdev-template-${TEMPLATE_NAME}-$(date +%s)-$$"

  set +e
  mkdir -p "$tmp/template" &&
    (cd "$td" && tar -cf - .) | (cd "$tmp/template" && tar -xf -) &&
    dc exec -T "$svc" sh -lc "rm -rf '$remote_dir' && mkdir -p '$remote_dir'" &&
    (cd "$tmp/template" && tar -cf - .) | dc exec -T "$svc" sh -lc "tar -xf - -C '$remote_dir'" &&
    dc exec -T \
      -e CODER_URL="$CODER_URL" \
      -e CODER_SESSION_TOKEN="$CODER_SESSION_TOKEN" \
      "$svc" \
      coder templates push --yes --directory "$remote_dir" "$TEMPLATE_NAME"
  rc=$?
  set -e

  dc exec -T "$svc" sh -lc "rm -rf '$remote_dir'" >/dev/null 2>&1 || true
  rm -rf "$tmp"

  return "$rc"
}

# ---------------------------------------------------------------------------
# check-generated -- validate a generated template tree
# ---------------------------------------------------------------------------
cmd_check_generated() {
  local td="$1"
  if [[ -z "$td" ]]; then
    td="$(template_dir 2>/dev/null || true)"
  fi
  [[ -n "$td" ]] || die "no template directory; pass one as argument"

  local errors=0

  # Must have a main.tf.json or main.tf
  if [[ ! -f "$td/main.tf.json" ]] && [[ ! -f "$td/main.tf" ]]; then
    err "missing main.tf.json (or main.tf) in $td"
    errors=$((errors + 1))
  fi

  # Must have startup.sh
  if [[ ! -f "$td/startup.sh" ]]; then
    err "missing startup.sh in $td"
    errors=$((errors + 1))
  fi

  # Must have runtime directory
  if [[ ! -d "$td/runtime" ]]; then
    err "missing runtime/ directory in $td"
    errors=$((errors + 1))
  fi

  # Check for forbidden patterns in main.tf.json
  if [[ -f "$td/main.tf.json" ]]; then
    if grep -q 'prevent_destroy' "$td/main.tf.json" 2>/dev/null; then
      err "main.tf.json contains prevent_destroy (forbidden)"
      errors=$((errors + 1))
    fi
    if grep -q '/var/run/docker.sock' "$td/main.tf.json" 2>/dev/null; then
      err "main.tf.json mounts docker socket (forbidden)"
      errors=$((errors + 1))
    fi
  fi

  if [[ "$errors" -gt 0 ]]; then
    err "check-generated: $errors error(s) found"
    return 1
  fi

  log "check-generated: OK ($td)"
  return 0
}

# ---------------------------------------------------------------------------
# check-images -- verify images referenced in the template exist in GHCR
# ---------------------------------------------------------------------------
cmd_check_images() {
  local td images_json
  td="${1:-$(template_dir 2>/dev/null || true)}"
  [[ -n "$td" ]] || die "no template directory"

  images_json="$td/images.json"
  if [[ ! -f "$images_json" ]]; then
    # Try generated/catalog path
    local cat_dir
    for cat_dir in "$td/../catalog" "$td/../../catalog" "$ROOT/generated/catalog"; do
      if [[ -f "$cat_dir/images.json" ]]; then
        images_json="$cat_dir/images.json"
        break
      fi
    done
  fi

  if [[ ! -f "$images_json" ]]; then
    warn "images.json not found; skipping image check"
    return 0
  fi

  log "checking images from $images_json"

  local image errors=0
  # Extract image references from the images.json
  while IFS= read -r image; do
    if [[ -z "$image" ]]; then continue; fi
    if have docker && docker buildx imagetools inspect "$image" >/dev/null 2>&1; then
      log "  found: $image"
    else
      err "  missing: $image"
      errors=$((errors + 1))
    fi
  done < <(python3 -c "
import json, sys
data = json.load(open('$images_json'))
for img in data.get('images', []):
    print(img.get('image', ''))
" 2>/dev/null || true)

  if [[ "$errors" -gt 0 ]]; then
    warn "check-images: $errors image(s) not found in registry"
    return 1
  fi
  log "check-images: all images present"
  return 0
}

# ---------------------------------------------------------------------------
# sync-generated -- atomically update the template directory from generated
# ---------------------------------------------------------------------------
cmd_sync_generated() {
  need_root
  local generated_dir="$1"

  if [[ -z "$generated_dir" ]]; then
    generated_dir="$ROOT/generated"
  fi
  [[ -d "$generated_dir" ]] || die "generated directory not found: $generated_dir"

  local templates_subdir="$generated_dir/templates/$TEMPLATE_NAME"
  if [[ ! -d "$templates_subdir" ]]; then
    templates_subdir="$generated_dir/templates/devbox"
  fi
  [[ -d "$templates_subdir" ]] || die "template subdirectory not found under $generated_dir"

  local target_dir staging_dir
  target_dir="$(template_dir)"
  staging_dir="$(mktemp -d)"

  log "sync-generated: source=$templates_subdir target=$target_dir"

  # Acquire lock and perform atomic switch
  mkdir -p "$LOCK_DIR"

  (
    exec 9>"$LOCK_DIR/sync-generated.lock"
    if ! flock -n 9; then
      die "another sync-generated is already running"
    fi

    # Copy generated template into staging
    cp -a "$templates_subdir"/. "$staging_dir"/

    # Validate the staging copy
    if ! cmd_check_generated "$staging_dir"; then
      err "staging validation failed; aborting sync"
      rm -rf "$staging_dir"
      exit 1
    fi

    # Also validate image references if images.json exists
    if [[ -f "$generated_dir/catalog/images.json" ]]; then
      cp "$generated_dir/catalog/images.json" "$staging_dir/images.json" 2>/dev/null || true
    fi

    # Atomic switch: move old aside, move new in
    local old_dir="${target_dir}.prev.$(date +%s)"
    if [[ -d "$target_dir" ]]; then
      mv "$target_dir" "$old_dir"
    fi

    mv "$staging_dir" "$target_dir"

    # Clean up old directory
    if [[ -d "$old_dir" ]]; then
      /bin/rm -rf "$old_dir"
    fi
  )

  log "sync-generated: complete"
}

# ---------------------------------------------------------------------------
# list-workspace-volumes -- list Docker volumes with Coder labels (read-only)
# ---------------------------------------------------------------------------
cmd_list_workspace_volumes() {
  log "listing Docker volumes with Coder workspace labels"

  docker volume ls --format '{{.Name}}' 2>/dev/null | while read -r vol; do
    local labels
    labels="$(docker volume inspect "$vol" --format '{{json .Labels}}' 2>/dev/null || true)"
    if [[ -n "$labels" && "$labels" != "null" ]] && echo "$labels" | grep -q 'coder.workspace_id'; then
      local ws_id owner
      ws_id="$(echo "$labels" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('coder.workspace_id','?'))" 2>/dev/null || echo '?')"
      owner="$(echo "$labels" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('coder.owner','?'))" 2>/dev/null || echo '?')"
      printf '  %-50s  ws=%-36s  owner=%s\n' "$vol" "$ws_id" "$owner"
    fi
  done

  echo
  warn "Volumes above are managed by Coder.  Do NOT delete them manually."
  warn "Normal Coder workspace deletion removes the volume automatically."
}

# ---------------------------------------------------------------------------
# install-self
# ---------------------------------------------------------------------------
cmd_install_self() {
  need_root
  install -m 0755 "$0" /usr/local/bin/cdev
  log "installed to /usr/local/bin/cdev"
}

# ---------------------------------------------------------------------------
# usage
# ---------------------------------------------------------------------------
usage() {
  cat <<'HELP'
cdev - thin VPS helper for CoderVPS

  cdev info                        show configuration summary
  cdev doctor                      full health check
  cdev ps                          show Docker Compose services
  cdev logs [service]              tail logs (default: coder service)
  cdev restart [service]           restart services

  cdev template-dir                print active template directory path
  cdev push-template               push template to Coder (requires CODER_SESSION_TOKEN)

  cdev sync-generated <dir>        atomically sync generated template tree to active dir
  cdev check-generated [dir]       validate a generated template tree
  cdev check-images [dir]          verify template images exist in GHCR

  cdev list-workspace-volumes      list Coder-managed workspace volumes (never deletes)
  cdev install-self                install cdev to /usr/local/bin

Environment:
  DOMAIN=code.549304.xyz
  CODER_CDE_ROOT=/opt/coder-cde
  TEMPLATE_DIR=/opt/coder-cde/templates/devbox
  TEMPLATE_NAME=devbox
  CODER_SESSION_TOKEN=...
  CODER_URL=https://code.549304.xyz
HELP
}

# ---------------------------------------------------------------------------
# dispatch
# ---------------------------------------------------------------------------
main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
  help | -h | --help) usage ;;
  version | --version) echo "$VERSION" ;;
  info) cmd_info "$@" ;;
  doctor) cmd_doctor "$@" ;;

  ps) cmd_ps "$@" ;;
  logs) cmd_logs "$@" ;;
  restart) cmd_restart "$@" ;;

  template-dir) cmd_template_dir "$@" ;;
  push-template) cmd_push_template "$@" ;;

  sync-generated) cmd_sync_generated "$@" ;;
  check-generated) cmd_check_generated "$@" ;;
  check-images) cmd_check_images "$@" ;;

  list-workspace-volumes) cmd_list_workspace_volumes "$@" ;;
  install-self) cmd_install_self "$@" ;;

  *)
    err "unknown command: $cmd"
    usage
    exit 2
    ;;
  esac
}

main "$@"
